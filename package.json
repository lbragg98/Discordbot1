  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "discord.js": "^14.26.3",
    "dotenv": "^17.4.2",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
